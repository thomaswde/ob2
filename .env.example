DATABASE_URL=postgres://ob2:ob2@127.0.0.1:54329/ob2
OB2_LLM_BACKEND=anthropic-api
OB2_LLM_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OB2_EMBEDDING_API_KEY=
# Optional override for OpenRouter or another OpenAI-compatible endpoint.
OB2_EMBEDDING_BASE_URL=https://api.openai.com/v1
OB2_EMBEDDING_MODEL=text-embedding-3-small
OB2_EMBEDDING_DIMENSIONS=1536
# Set to 0 to disable embeddings even when an API key is present.
OB2_EMBEDDINGS_ENABLED=1
OB2_API_TOKEN=
# Optional: client-scoped tokens in client_id:token form, comma-separated.
# OB2_API_CLIENT_TOKENS=default:replace-me
OB2_API_HOST=127.0.0.1
OB2_API_PORT=4318
OB2_AUTOMATION_ENABLED=0
OB2_PENDING_CONSOLIDATION_THRESHOLD=50
OB2_AUTOMATION_LOCK_FILE=.ob2-consolidate.lock
